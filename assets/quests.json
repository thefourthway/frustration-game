            ],
            "drops": [
                {
                    "dist_type": "all_of",
                    "items": [
                        {"type": "pot", "id": "pot"},
                        {"type": "ramen_bowl", "id": "ramen_bowl"}
                    ]
                }
            ],
            "next": "make_ramen_5"
        },
        {
            "id": "make_ramen_5",
            "name": "Eat your ramen",
            "objectives": [
                {"type": "item", "target": "ramen_bowl", "description": "Eat your ramen"}
            ]
        }
