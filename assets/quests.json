            "name": "Pay the late bill",
            "objectives": [
                {"type": "collect", "target": "cash", "description": "Grab your cash"},
                {
                    "type": "interact", "target": "bill_to_pay", "description": "Put the cash with the bill",
                    "requires": [
                        {"type": "held_item", "item": "cash"}
                    ]
                }
            ],
            "drops": [
                {
                    "dist_type": "all_of",
