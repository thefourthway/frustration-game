                        {"type": "bill_envelope", "id": "bill_envelope"}
                    ]
                }
            ],
            "next": "pay_the_bill_2"
        },
        {
            "id": "pay_the_bill_2",
            "name": "Mail the paid bill",
            "objectives": [
                {
                    "type": "interact", "target": "mailbox", "description": "Put the bill in the mailbox",
                    "requires": [
                        {"type": "held_item", "item": "bill_envelope"}
                    ]
                }
            ]
        },
        {
            "id": "answer_the_phone",
            "name": "Answer the phone!",
            "objectives": [
                {
                    "type": "interact", "target": "phone", "description": "Answer the phone!!",
                    "requires": [
                        {"type": "wait_at", "location": "phone", "duration": 6.0}
                    ]
                }
            ]
        },
        {
            "id": "make_ramen_1",
            "name": "Make some ramen",
            "objectives": [
                {"type": "collect", "target": "pot", "description": "Get the pot"},
                {"type": "interact", "target": "sink", "description": "Put water in the pot", "requires": [
                    {"type": "held_item", "item": "pot"}
                ]}
            ],
            "drops": [
                {
                    "dist_type": "all_of",
                    "items": [
                        {"type": "filled_pot", "id": "filled_pot"}
                    ]
                }
            ],
            "next": "make_ramen_2"
        },
        {
            "id": "make_ramen_2",
            "name": "Make some ramen",
            "objectives": [
                {
                    "type": "interact", "target": "stove", "description": "Boil some water",
                    "requires": [
                        {"type": "held_item", "item": "full_pot"}
                    ]
                }
            ],
            "next": "make_ramen_3"
        },
        {
            "id": "make_ramen_3",
            "name": "Make some ramen",
            "objectives": [
                {"type": "collect", "target": "ramen", "description": "Grab the ramen"},
                {"type": "deposit", "target": "full_pot", "description": "Cook the ramen"}
